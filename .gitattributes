# ============================================================
# Git Attributes - AssureFlow Platform
# ============================================================
# Ensure consistent line endings across Windows and Linux
# ============================================================

# Set default behavior to LF (Linux-style) for all text files
* text=auto

# Explicitly declare text files to use LF
*.sh text eol=lf
*.bash text eol=lf
*.sql text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.java text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.env text eol=lf
Dockerfile text eol=lf
.dockerignore text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Binary files - no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.pdf binary
*.jar binary
*.war binary
*.ear binary
*.class binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
