# ============================================================
# AssureFlow - Environment Configuration
# ============================================================
# 📋 COPY THIS FILE TO .env AND CUSTOMIZE FOR YOUR ENVIRONMENT
# Command: cp .env.example .env
# 
# ⚠️ IMPORTANT: DO NOT COMMIT .env FILE TO VERSION CONTROL!
# ============================================================

# ============================================================
# 🗄️ PostgreSQL Configuration
# ============================================================
POSTGRES_USER=assureflow
POSTGRES_PASSWORD=assureflow_secure_2024
POSTGRES_DB=assureflow

# ============================================================
# 🗄️ pgAdmin Configuration
# ============================================================
PGADMIN_DEFAULT_EMAIL=admin@assureflow.com
PGADMIN_DEFAULT_PASSWORD=admin_secure_2024


# ============================================================
# 📨 Kafka Configuration
# ============================================================
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ============================================================
# 🔐 JWT Configuration (Base64 encoded, minimum 256 bits)
# ============================================================
# Generate with: openssl rand -base64 32
JWT_SECRET=QXNzdXJlRmxvd1NlY3JldEtleTIwMjRWZXJ5TG9uZ0FuZFNlY3VyZUZvckpXVFRva2VuR2VuZXJhdGlvbkFuZFZhbGlkYXRpb24=

# ============================================================
# 🔑 Service Account Tokens (for inter-service communication)
# ============================================================
# These tokens are used for communication between microservices
# They are generated automatically at IAM-service startup
#
# HOW TO GENERATE NEW TOKENS:
# 1. Start IAM-service: docker-compose up iam-service
# 2. Check logs: docker-compose logs iam-service | grep "SERVICE_ACCOUNT_TOKEN"
# 3. OR call API: curl -H "Authorization: Bearer <ADMIN_TOKEN>" http://localhost:8081/api/v1/service-tokens/generate
# 4. Copy the new tokens below
#
# IMPORTANT: These tokens must be synchronized across all microservices
# Validity: 10 years (renew before expiration)

# Main token for inter-service calls (Feign, Kafka consumers)
# Subject: service-account | Roles: ROLE_SERVICE, ROLE_ADMIN | Validity: 10 years
SERVICE_ACCOUNT_TOKEN=eyJhbGciOiJIUzI1NiJ9.eyJyb2xlcyI6WyJST0xFX1NFUlZJQ0UiLCJST0xFX0FETUlOIl0sInN1YiI6InNlcnZpY2UtYWNjb3VudCIsImlhdCI6MTc3NTAzMDYwNiwiZXhwIjoyMDkwMzkwNjA2fQ.YOUR_TOKEN_HERE

# Legacy token for compatibility with old services
# Subject: feign-client-service | Roles: ROLE_SERVICE | Validity: 10 years
FEIGN_CLIENT_JWT_TOKEN=eyJhbGciOiJIUzI1NiJ9.eyJyb2xlcyI6WyJST0xFX1NFUlZJQ0UiXSwic3ViIjoiZmVpZ24tY2xpZW50LXNlcnZpY2UiLCJpYXQiOjE3NzUwMzA2MDYsImV4cCI6MjA5MDM5MDYwNn0.YOUR_TOKEN_HERE

# ============================================================
# 🌱 Spring Profile
# ============================================================
SPRING_PROFILES_ACTIVE=docker

# ============================================================
# 🗄️ Database URLs (one per microservice)
# ============================================================
POLICY_DB_URL=jdbc:postgresql://postgres-db:5432/policy_db
CLIENT_DB_URL=jdbc:postgresql://postgres-db:5432/client_db
BILLING_DB_URL=jdbc:postgresql://postgres-db:5432/billing_db
CLAIMS_DB_URL=jdbc:postgresql://postgres-db:5432/claims_db
NOTIFICATION_DB_URL=jdbc:postgresql://postgres-db:5432/notification_db
IAM_DB_URL=jdbc:postgresql://postgres-db:5432/iam_db
WORKFLOW_DB_URL=jdbc:postgresql://postgres-db:5432/workflow_db

# ============================================================
# 📧 Email Configuration (for Notification Service)
# ============================================================
# Gmail SMTP Configuration:
# 1. Enable 2FA on your Google Account
# 2. Generate App Password at: https://myaccount.google.com/apppasswords
# 3. Use the 16-character app password (WITHOUT SPACES)
#
# For production, use your company's SMTP server
# ============================================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_FROM=your-email@gmail.com

# Spring Mail Configuration (duplicate for compatibility)
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your-email@gmail.com
SPRING_MAIL_PASSWORD=your-16-char-app-password

# ============================================================
# 📱 Twilio SMS Configuration (for Notification Service)
# ============================================================
# Get your credentials from: https://console.twilio.com
# 1. Account SID: Found on Twilio Console Dashboard
# 2. Auth Token: Found on Twilio Console Dashboard (click "Show")
# 3. Phone Number: Buy a Twilio phone number (free trial available)
# ============================================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# ============================================================
# 🔔 Notification Settings
# ============================================================
# Enable/disable notification channels
NOTIFICATION_EMAIL_ENABLED=true
NOTIFICATION_SMS_ENABLED=true
NOTIFICATION_IN_APP_ENABLED=true

# ============================================================
# 🌍 Application URLs
# ============================================================
FRONTEND_URL=http://localhost:4200
BACKEND_URL=http://localhost:8080
API_GATEWAY_URL=http://localhost:8080

# ============================================================
# 📊 Monitoring & Logging
# ============================================================
LOG_LEVEL=INFO
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE=health,info,metrics

# ============================================================
# 🚀 Quick Start Guide
# ============================================================
# 1. Copy this file: cp .env.example .env
# 2. Generate JWT_SECRET: openssl rand -base64 32
# 3. Configure Gmail: Get App Password from Google
# 4. Configure Twilio: Get credentials from console.twilio.com
# 5. Start services: docker-compose up -d
# 6. Check logs: docker logs -f
#
# For detailed setup instructions, see: NOTIFICATIONS_SETUP.md
# ============================================================

