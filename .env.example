# ============================================================
# 🔧 AssureFlow - Environment Variables Example
# ============================================================
# Copy this file to .env and adjust the values as needed
# NEVER commit .env to source control (it's gitignored)
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=assureflow
POSTGRES_PASSWORD=assureflow123
POSTGRES_DB=assureflow_db

# --- pgAdmin ---
PGADMIN_DEFAULT_EMAIL=admin@assureflow.com
PGADMIN_DEFAULT_PASSWORD=admin123

# --- Redis ---
REDIS_PASSWORD=redis123
REDIS_HOST=redis
REDIS_PORT=6379

# --- Spring Profiles ---
SPRING_PROFILES_ACTIVE=docker

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# --- JWT (use a strong secret in production) ---
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970

# --- Grafana ---
GRAFANA_PASSWORD=grafana123

# --- Service Database URLs ---
IAM_DB_URL=jdbc:postgresql://postgres-db:5432/iam_db
CLIENT_DB_URL=jdbc:postgresql://postgres-db:5432/client_db
POLICY_DB_URL=jdbc:postgresql://postgres-db:5432/policy_db
BILLING_DB_URL=jdbc:postgresql://postgres-db:5432/billing_db
CLAIMS_DB_URL=jdbc:postgresql://postgres-db:5432/claims_db
NOTIFICATION_DB_URL=jdbc:postgresql://postgres-db:5432/notification_db
WORKFLOW_DB_URL=jdbc:postgresql://postgres-db:5432/workflow_db
